<%# Using local variable message instead of calling helper to avoid issues in background jobs %>
<% current_user = local_assigns[:current_user] || (respond_to?(:simple_chat_current_user) ? simple_chat_current_user : nil) %>
<div id="<%= dom_id message %>" class="flex items-start mb-4 <%= message.user == current_user ? 'justify-end' : 'justify-start' %>">
  <div class="max-w-[70%] rounded-lg px-4 py-2 <%= message.user == current_user ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-900' %>">
    <div class="text-xs mb-1 font-semibold <%= message.user == current_user ? 'text-blue-100 text-right' : 'text-gray-600' %>">
      <%= message.user.respond_to?(:name) ? message.user.name : "User ##{message.user_id}" %>
    </div>

    <div class="text-sm">
      <%= message.content %>
    </div>

    <div class="text-[10px] mt-1 opacity-70 <%= message.user == current_user ? 'text-right' : '' %>">
      <%= message.created_at.strftime("%H:%M") %>
    </div>
  </div>
</div>
